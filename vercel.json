{
  "version": 2,
  "installCommand": "npm install && npm install --prefix frontend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/app" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ]
}
